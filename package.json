{
  "name": "coop-tafernout",
  "version": "1.0.0",
  "description": "COOP TAFERNOUT — Système de Gestion Pâtisserie",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "generate-license": "node generate-license.js",
    "dev": "vite",
    "build-web": "vite build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ma.cooptafernout.gestion",
    "productName": "Coop Tafernout ERP",
    "copyright": "Copyright © 2025 Coop Tafernout",
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Coop Tafernout ERP"
    },
    "files": [
      "main.js",
      "preload.js",
      "license-codes.json",
      "src/**/*",
      "python_tools/**/*",
      "python_apps/**/*",
      "requirements.txt",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.js"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "crypto-js": "^4.2.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.1",
    "jsonwebtoken": "^9.0.3",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^14.0.0",
    "vite": "^8.0.11"
  }
}
